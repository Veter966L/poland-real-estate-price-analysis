   "source": [
    "#Group dataset by cities and count advertisment\n",
    "aparts_by_city = pol_aparts.groupby('city')['price'].agg('count').sort_values(ascending=False).reset_index() #Create series and delete indexes\n",
    "aparts_by_city.columns = ['city', 'count'] #Transform series to dataframe with columns\n",
    "aparts_by_city['count_perc'] = round(aparts_by_city['count'] * 100 /\n",
    "                                     aparts_by_city['count'].sum(),\n",
    "                                     2) # Add extra columns with count advertisment in procente and round to 2 sign after comma\n",
    "print(f'Dataset consist information about {aparts_by_city.shape[0]} cities')\n",
    "\n",
    "#Confiigure and build schedule\n",
    "plt.figure(figsize=(10, 6)) #Make the chart more wide for good view\n",
    "adv_by_city_plt = sns.barplot(data=aparts_by_city,\n",
    "                              x='city',\n",
    "                              y='count_perc') #Visualize the value of each city on the chart\n",
    "adv_by_city_plt.bar_label(adv_by_city_plt.containers[0]) #Display percentege above every column\n",
    "plt.xticks(rotation=90) #Reverse the names of city for clear reading\n",
    "plt.title('Distribution of advertisements by city') #Title of graph\n",
    "plt.xlabel('City') # X-axis label\n",
    "plt.ylabel('Number adv in %') # Y-axis label\n",
    "plt.show()\n",
    "\n"
   ]
  },
