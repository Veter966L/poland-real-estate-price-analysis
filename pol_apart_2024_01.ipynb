   "source": [
    "#Create function to sort build years fro decade\n",
    "\n",
    "def age_category(year):\n",
    "    if year < 1945: return 'Pre-war'\n",
    "    if 1945 <= year < 1991: return 'Soviet/Post-war'\n",
    "    if 1991 <= year < 2000: return 'Modern 2000'\n",
    "    if 2000 <= year < 2010: return 'Modern 2010'\n",
    "    if 2010 <= year < 2020: return 'Modern 2020'\n",
    "    return 'Brand New'\n",
    "\n",
    "pol_aparts['buildingEra'] = pol_aparts['buildYear'].apply(age_category) # Create new column and assign value according to decade\n",
    "\n",
    "plt.figure(figsize=(10, 6)) # Determine figure size\n",
    "sns.boxplot(data=pol_aparts,\n",
    "            x='buildingEra',\n",
    "            y='price', \n",
    "            order=['Pre-war', 'Soviet/Post-war', 'Modern 2000', 'Modern 2010', 'Modern 2020', 'Brand New']) # Create box plot\n",
    "plt.title('Price depends from decade of build') # Write title\n",
    "plt.show() #Display"
   ]
  },
