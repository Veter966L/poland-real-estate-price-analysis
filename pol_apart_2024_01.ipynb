    "\n",
    "# Create loop\n",
    "for feature in cat_features:\n",
    "    plt.figure(figsize=(17, 9))\n",
    "    \n",
    "    # Build graph\n",
    "    sns.boxplot(\n",
    "        data=df_top, \n",
    "        x='city', \n",
    "        y='price_per_m2', \n",
    "        hue=feature,\n",
    "        order=top_cities, # Set order of cities with ascending\n",
    "        palette='Set2'\n",
    "    )\n",
    "    \n",
    "    # Set style\n",
    "    plt.title(f'Influence \"{feature}\" on price per square meter in top-10 cities', fontsize=15)\n",
    "    plt.xticks(rotation=45)\n",
    "    plt.ylabel('Price per square meter (PLN)')\n",
    "    plt.xlabel('City')\n",
    "    plt.grid(axis='y', linestyle='--', alpha=0.7) # Сетка для удобства сравнения цен\n",
    "    plt.legend(title=feature, bbox_to_anchor=(1.05, 1), loc='upper left') # Выносим легенду\n",
    "    \n",
    "    plt.show()"
   ]
