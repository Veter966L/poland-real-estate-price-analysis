    "# Define the data directory\n",
    "data_path = 'datasets/archive1/'\n",
    "\n",
    "# Collect all CSV files and sort them to maintain chronological order\n",
    "all_files = sorted(glob.glob(os.path.join(data_path, \"*.csv\")))\n",
    "\n",
    "# Split files based on your project structure: 11 for sales, 8 for rent\n",
    "sales_files = all_files[:11]\n",
    "rent_files = all_files[11:]\n",
    "\n",
    "def load_real_estate_data(file_list, category_label):\n",
    "    \"\"\"\n",
    "    Reads multiple CSV files, extracts dates from filenames, \n",
    "    and merges them into a single cleaned DataFrame.\n",
    "    \"\"\"\n",
    "    temp_list = []\n",
    "    \n",
    "    for file in file_list:\n",
    "        # Load the dataset\n",
    "        df = pd.read_csv(file)\n",
    "        \n",
    "        # Extract filename (e.g., 'apartments_pl_2023_08.csv')\n",
    "        base_name = os.path.basename(file)\n",
    "        \n",
    "        # Parse Year and Month from the filename string\n",
    "        # We split by '_' and take the last two parts before '.csv'\n",
    "        name_parts = base_name.replace('.csv', '').split('_')\n",
    "        file_year = name_parts[-2]\n",
    "        file_month = name_parts[-1]\n",
    "        \n",
    "        # Add metadata columns for time-series analysis\n",
    "        df['year'] = file_year\n",
    "        df['month'] = file_month\n",
    "        df['offer_type'] = category_label\n",
    "        \n",
    "        temp_list.append(df)\n",
    "        print(f\"Processed {category_label}: {file_year}-{file_month}\")\n",
    "        \n",
    "    # Combine all files into one DataFrame\n",
    "    full_df = pd.concat(temp_list, ignore_index=True)\n",
    "    \n",
    "    # Remove duplicate listings that appear in multiple months\n",
    "    full_df = full_df.drop_duplicates()\n",
    "    \n",
    "    return full_df\n",
    "\n",
    "# Load the Sale and Rent datasets\n",
    "df_sales = load_real_estate_data(sales_files, 'sale')\n",
    "df_rent = load_real_estate_data(rent_files, 'rent')"
   ]
